# FixMo Backend — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT secret (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Webhook signature verification (optional; set in Supabase webhook config)
SUPABASE_WEBHOOK_SECRET=your-webhook-hmac-secret

# Email notifications (Gmail with app-specific password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Server
PORT=3001
LOG_LEVEL=info
NODE_ENV=development
