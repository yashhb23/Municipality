# FixMo Flutter — Build-time environment variables
# Copy this to dart_define.env and fill in real values.
# Usage: flutter run --dart-define-from-file=dart_define.env
#
# Also add GOOGLE_MAPS_API_KEY to android/local.properties for Android builds:
#   GOOGLE_MAPS_API_KEY=your-key-here

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
BACKEND_URL=http://10.0.2.2:3001
